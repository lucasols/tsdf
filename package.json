{
  "name": "tsdf",
  "version": "17.0.0",
  "description": "A data fetching solution based on t-state",
  "license": "MIT",
  "author": "Lucas Santos",
  "repository": "github:lucasols/tsdf",
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "test": "vitest --mode development",
    "test:ui": "vitest --ui --mode development",
    "test:changed": "vitest --changed --mode development",
    "lint": "pnpm tsc && pnpm eslint && pnpm format",
    "eslint": "eslint src/ tests/ --fix",
    "format": "oxfmt src/ tests/",
    "tsc": "tsc -p tsconfig.prod.json",
    "tsc:watch": "tsc -p tsconfig.prod.json --watch",
    "build": "pnpm vitest run && pnpm lint && pnpm build:no-test",
    "build:no-test": "tsup --dts",
    "pre-publish": "./scripts/check-if-is-sync.sh && pnpm build",
    "hooks:install": "simple-git-hooks",
    "hooks:uninstall": "git config --unset core.hooksPath || true && rm -rf .git/hooks/pre-commit"
  },
  "devDependencies": {
    "@ls-stack/eslint-cfg": "^0.5.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitest/ui": "4.0.16",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.0.11",
    "oxfmt": "^0.28.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "simple-git-hooks": "^2.13.1",
    "tiny-glob": "^0.2.9",
    "tsm": "^2.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@evtmitter/react": "^0.1.0",
    "@ls-stack/react-utils": "^0.9.0",
    "@ls-stack/utils": "^3.65.0",
    "evtmitter": "^1.0.2",
    "immer": "^11.1.3",
    "klona": "^2.0.6",
    "t-result": "^0.6.1",
    "t-state": "^9.8.1"
  },
  "simple-git-hooks": {
    "pre-commit": "node --no-warnings scripts/preCommitHook.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0||^19.0.0",
    "react-dom": "^18.0.0||^19.0.0"
  }
}
