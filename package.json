{
  "name": "tsdf",
  "version": "17.0.0",
  "description": "A data fetching solution based on t-state",
  "license": "MIT",
  "author": "Lucas Santos",
  "repository": "github:lucasols/tsdf",
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "test": "vitest --mode development",
    "test:ui": "vitest --ui --mode development",
    "test:changed": "vitest --changed --mode development",
    "lint": "pnpm tsc && pnpm eslint && pnpm format",
    "eslint": "CI=true eslint --color --ext .jsx,.js,.ts,.tsx src/ test/",
    "format": "prettier --write src/**/*.ts",
    "tsc": "tsc -p tsconfig.prod.json",
    "tsc:watch": "tsc -p tsconfig.prod.json --watch",
    "build": "pnpm vitest run && pnpm lint && pnpm build:no-test",
    "build:no-test": "tsup --dts",
    "pre-publish": "./scripts/check-if-is-sync.sh && pnpm build"
  },
  "devDependencies": {
    "@lucasols/eslint-plugin-extended-lint": "^1.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitest/ui": "4.0.16",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-vitest": "^0.5.4",
    "happy-dom": "^20.0.11",
    "prettier": "^3.7.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tiny-glob": "^0.2.9",
    "tsm": "^2.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@evtmitter/react": "^0.1.0",
    "@ls-stack/react-utils": "^0.9.0",
    "@ls-stack/utils": "^3.65.0",
    "evtmitter": "^1.0.2",
    "immer": "^11.1.3",
    "klona": "^2.0.6",
    "t-result": "^0.6.1",
    "t-state": "^9.8.1"
  },
  "peerDependencies": {
    "react": "^18.0.0||^19.0.0",
    "react-dom": "^18.0.0||^19.0.0"
  }
}
