{
  "name": "tsdf",
  "version": "17.0.0-alpha.10",
  "description": "A data fetching solution based on t-state",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Lucas Santos",
  "repository": "github:lucasols/tsdf",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    },
    "./async-storage": {
      "types": "./dist/async-storage.d.ts",
      "import": "./dist/async-storage.js",
      "default": "./dist/async-storage.js"
    },
    "./indexed-db-storage": {
      "types": "./dist/indexed-db-storage.d.ts",
      "import": "./dist/indexed-db-storage.js",
      "default": "./dist/indexed-db-storage.js"
    },
    "./opfs-storage": {
      "types": "./dist/opfs-storage.d.ts",
      "import": "./dist/opfs-storage.js",
      "default": "./dist/opfs-storage.js"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "knip": "knip",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:changed": "vitest --changed",
    "test:playwright": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest --run && playwright test",
    "lint": "pnpm lint:lib && pnpm --filter @tsdf/playground lint",
    "lint:lib": "pnpm tsc && pnpm tsc:isolated && pnpm eslint",
    "eslint": "eslint src/ tests/ --fix",
    "format": "oxfmt src/ tests/ apps/playground/src/",
    "tsc": "tsgo -p tsconfig.prod.json && tsgo -p tsconfig.playwright-fixture.json",
    "tsc:isolated": "tsgo -p tsconfig.isolated.json",
    "playground": "pnpm --filter @tsdf/playground dev",
    "playground:build": "pnpm --filter @tsdf/playground build",
    "build": "pnpm lint && pnpm test:all && pnpm build:no-test",
    "build:no-test": "tsdown",
    "pre-publish": "pnpm build",
    "hooks:install": "simple-git-hooks",
    "hooks:uninstall": "git config --unset core.hooksPath || true && rm -rf .git/hooks/pre-commit"
  },
  "devDependencies": {
    "@ls-stack/eslint-cfg": "^0.10.0",
    "@ls-stack/extended-lint": "^0.89.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.4",
    "knip": "^6.4.1",
    "oxfmt": "^0.40.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@evtmitter/react": "^0.1.0",
    "@ls-stack/browser-utils": "^0.3.0",
    "@ls-stack/react-utils": "^0.12.1",
    "@ls-stack/utils": "^3.76.0",
    "@standard-schema/spec": "^1.1.0",
    "evtmitter": "^1.0.2",
    "klona": "^2.0.6",
    "runcheck": "^1.15.0",
    "t-result": "^0.6.1",
    "t-state": "^9.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "node --no-warnings scripts/preCommitHook.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0||^19.0.0",
    "react-dom": "^18.0.0||^19.0.0"
  }
}
